# Match both real dirs and stray symlinks named node_modules (a trailing-slash
# pattern ignores dirs only — symlinks slipped through and got committed once).
node_modules/
node_modules
dist/
target/
.env
.env.local
*.log
.DS_Store
coverage/
.turbo/

# Tauri build artifacts
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/
.vercel
.env*.local

# Nested separate repos (do not commit as part of OSS)
/homebrew-ato/


# CLI build artifacts (apps/cli has its own target/ dir)
apps/cli/target/

# Sidecar binaries are built per-target in CI; ignored locally
apps/desktop/src-tauri/binaries/

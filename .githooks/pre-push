#!/usr/bin/env bash
# Pre-push gate — full checks (target ≤2min).
#
# Runs everything pre-commit does, plus release builds and the ATO CLI
# agentic-usage smoke. If a push makes it through this gate, every
# read-only CLI surface returns clean and every build still compiles.
#
# What's NOT here:
# - tsc — see ROADMAP.md § "Gate + TS cleanup week" (joins by 2026-05-22).
# - `ato dispatch` / `runtimes test-providers` — paid LLM calls. Belong in
#   the release script and a daily `ato doctor` cron, not in routine push.
# - mutating CLI commands — those need a throwaway test DB harness; future.
# - `ato mesh discovered` — listed initially but flagged by codex review
#   (MEDIUM #2): it opens the DB read-write and creates the file if absent,
#   which makes the gate non-hermetic. Dropped pending fix in apps/cli.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

step() { printf "\033[1;36m→\033[0m %s\n" "$1"; }
fail() { printf "\033[1;31m✗ pre-push gate failed at: %s\033[0m\n" "$1"; exit 1; }

# Portable per-command timeout. macOS lacks GNU `timeout` by default; use
# `perl -e 'alarm shift; exec @ARGV'` which is in every macOS / Linux base
# install. Added per claude review LOW #6 — keeps gate's ≤2min promise even
# under flaky-network / hung subcommand.
run_with_timeout() {
  local secs="$1"; shift
  perl -e 'alarm shift; exec @ARGV' "$secs" "$@"
}

step "cargo check (apps/desktop/src-tauri)"
(cd apps/desktop/src-tauri && cargo check --quiet) || fail "cargo check"

step "cargo build --release (apps/cli)"
(cd apps/cli && cargo build --release --quiet) || fail "cargo build CLI"

# Capture vite output on failure so the developer sees WHY (claude review
# MEDIUM #1: original redirect to /dev/null left the failed-step message
# context-free).
step "vite build (apps/desktop)"
VITE_LOG="$(mktemp)"
if ! (cd apps/desktop && npx vite build) >"$VITE_LOG" 2>&1; then
  cat "$VITE_LOG"
  rm -f "$VITE_LOG"
  fail "vite build"
fi
rm -f "$VITE_LOG"

step "vitest (apps/desktop)"
(cd apps/desktop && npx vitest run --reporter=dot) || fail "vitest"

# Skip CLI smoke when local.db isn't present — the CLI's read-only helpers
# hard-fail with a "DB not found" message that points users at install
# instructions. Per codex review HIGH #1: a fresh-clone gate must not couple
# to each contributor's personal ATO install state. When the DB is missing
# (CI, never-launched ATO), we still want commits/pushes to flow.
ATO="apps/cli/target/release/ato"
DB_PATH="${HOME}/.ato/local.db"

if [ ! -x "$ATO" ]; then
  fail "ato binary missing at $ATO (the cargo build step above should have produced it)"
fi

if [ ! -f "$DB_PATH" ]; then
  printf "\033[1;33m⚠ skipping ato CLI smoke — no local DB at %s (run the desktop once to populate)\033[0m\n" "$DB_PATH"
else
  step "ato CLI agentic-usage smoke (read-only commands)"
  SMOKE_CMDS=(
    "--help"
    "runtimes status"
    "runtimes health"
    "runtimes list-remote"
    "sessions list"
    "agents list"
    "recipes list"
    "recipes templates"
    "events recent"
    "posts list"
    "posts pending"
    "dispatches recent"
    "runs live"
    "regressions list"
    "cost recommendations"
    "daemon status"
    "ratchet list"
    "ratchet status"
  )

  for cmd in "${SMOKE_CMDS[@]}"; do
    # Word-split intentional — each entry is "subcommand args" as one string.
    # 10s ceiling per command keeps the gate's ≤2-min total promise even on a
    # flaky/captive network. claude review LOW #6.
    if ! run_with_timeout 10 $ATO $cmd > /dev/null 2>&1; then
      fail "ato $cmd (rc=$? — possibly timeout if hung >10s)"
    fi
  done

  printf "\033[1;32m✓ pre-push gate passed (%d CLI commands)\033[0m\n" "${#SMOKE_CMDS[@]}"
  exit 0
fi

printf "\033[1;32m✓ pre-push gate passed (CLI smoke skipped — no DB)\033[0m\n"

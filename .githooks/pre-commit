#!/usr/bin/env bash
# Pre-commit gate — fast checks (target ≤30s).
#
# Catches type errors and broken unit tests before they get committed.
# Heavier checks (release builds, CLI smoke) live in pre-push.
#
# 2026-05-20 — tsc joined the gate after the v2.7.6 TS debt cleanup
# (151 → 0 errors in 7 root-cause fixes + 1-day grind). Every commit
# now goes through Rust check, type check, and vitest before landing.
#
# 2026-06-13 — worktree-aware mode (FOLLOWUPS #4): mission worktrees
# at ~/.ato/missions/<slug>/{worktrees,integration}/ are spawned without
# the tauri sidecar binary or node_modules, so desktop/tsc/vitest fail
# purely on missing-dependency grounds even when the diff is sound.
# In a mission worktree we run a REDUCED gate (CLI cargo check only)
# and skip the desktop steps. Set ATO_PRECOMMIT_FORCE_FULL=1 to force
# the full gate from any path.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

step() { printf "\033[1;36m→\033[0m %s\n" "$1"; }
fail() { printf "\033[1;31m✗ pre-commit gate failed at: %s\033[0m\n" "$1"; exit 1; }

IS_MISSION_WORKTREE=0
if [ "${ATO_PRECOMMIT_FORCE_FULL:-0}" != "1" ]; then
  case "$PWD" in
    *"/.ato/missions/"*"/worktrees/"*) IS_MISSION_WORKTREE=1 ;;
    *"/.ato/missions/"*"/integration"*) IS_MISSION_WORKTREE=1 ;;
  esac
fi

if [ "$IS_MISSION_WORKTREE" = "1" ]; then
  printf "\033[1;33m→ mission worktree detected — running REDUCED gate\033[0m\n"
  step "cargo check (apps/cli)"
  (cd apps/cli && cargo check --quiet) || fail "cargo check CLI"
  printf "\033[1;32m✓ pre-commit gate (reduced) passed\033[0m\n"
  printf "\033[1;33m  (skipped: desktop cargo check, tsc, vitest — main repo runs full gate)\033[0m\n"
  exit 0
fi

step "cargo check (apps/desktop/src-tauri)"
(cd apps/desktop/src-tauri && cargo check --quiet) || fail "cargo check desktop"

# Added per v2.7.6 review (claude MEDIUM #2): CLI is half the Rust surface;
# shifting it left saves catching a CLI break at push time after a 30s build.
step "cargo check (apps/cli)"
(cd apps/cli && cargo check --quiet) || fail "cargo check CLI"

step "tsc --noEmit (apps/desktop)"
(cd apps/desktop && npx tsc --noEmit) || fail "tsc"

step "vitest (apps/desktop)"
(cd apps/desktop && npx vitest run --reporter=dot) || fail "vitest"

printf "\033[1;32m✓ pre-commit gate passed\033[0m\n"

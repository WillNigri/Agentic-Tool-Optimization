    {
      "id": "filesystem",
      "name": "Filesystem",
      "description": "Read and write local files. Useful for agents that need to inspect or edit project files.",
      "category": "files",
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem",
      "install": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "$PROJECT_PATH"]
      }
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Create issues, comment on PRs, search code across your repositories.",
      "category": "dev",
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/github",
      "install": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "" }
      },
      "authNote": "Requires GITHUB_PERSONAL_ACCESS_TOKEN with repo + issues scope."
    },
    {
      "id": "postgres",

{
  "name": "@ato-sdk/js",
  "version": "0.3.0",
  "description": "Trace forwarder for ATO-authored agents deployed outside the desktop app. Not a general-purpose LLM observability SDK — for that, use Langfuse, Helicone, or LangSmith.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./anthropic": {
      "import": "./dist/anthropic.mjs",
      "require": "./dist/anthropic.js",
      "types": "./dist/anthropic.d.ts"
    },
    "./openai": {
      "import": "./dist/openai.mjs",
      "require": "./dist/openai.js",
      "types": "./dist/openai.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.mjs",
      "require": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/anthropic.ts src/openai.ts src/agent.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/anthropic.ts src/openai.ts src/agent.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "ato",
    "agentictool",
    "ai-agents",
    "agent-deployment",
    "trace-forwarder"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WillNigri/Agentic-Tool-Optimization"
  },
  "homepage": "https://agentictool.ai",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "openai": { "optional": true },
    "claude-agent-sdk": { "optional": true }
  }
}
